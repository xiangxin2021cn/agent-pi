{
  "name": "@craft-agent/server",
  "version": "0.10.3",
  "description": "Standalone headless Agent Pi server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "craft-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "xiangxin2021cn",
    "email": "xiangxin2021cn@users.noreply.github.com"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/xiangxin2021cn/agent-pi",
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@craft-agent/core": "workspace:*",
    "@craft-agent/messaging-gateway": "workspace:*",
    "@craft-agent/server-core": "workspace:*",
    "@craft-agent/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0",
    "ws": "^8.16.0"
  }
}
